{
  project: {
    name: "domtrip",
    description: "DomTrip XML editing library",
  },

  tools: {
    java: {
      version: "21",
      distribution: "temurin",
    },
    maven: {
      version: "4.0.0-rc-5",
    },
  },

  commands: {
    build: {
      description: "Build the project",
      script: "mvn install -V",
    },

    test: {
      description: "Run tests",
      script: "mvn test -V",
    },

    clean: {
      description: "Clean build artifacts",
      script: "mvn clean",
    },
  },
}
